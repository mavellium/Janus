generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DEFAULT
  DEVELOPER

  @@map("user_role")
}

enum ProjectType {
  LANDING_PAGE
  INSTITUTIONAL

  @@map("project_type")
}

model Company {
  id               String    @id @default(uuid()) @db.Uuid
  slug             String    @unique
  name             String
  description      String?
  logo             String?
  guestModeEnabled Boolean   @default(false) @map("guest_mode_enabled")
  createdById      String?   @db.Uuid @map("created_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  users        User[]
  projects     Project[]
  guestEntries GuestEntry[]

  @@index([slug])
  @@index([deletedAt])
  @@index([createdById])
  @@map("companies")
}

model GuestEntry {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  companyId String   @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  posts     GuestPost[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([email, companyId])
  @@index([companyId])
  @@map("guest_entries")
}

model GuestPost {
  id        String   @id @default(uuid()) @db.Uuid
  title     String?
  message   String   @db.Text
  imageUrl  String
  guestId   String   @db.Uuid
  guest     GuestEntry @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guestId])
  @@map("guest_posts")
}

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  email                  String    @unique
  password               String    @db.Text
  name                   String?
  phone                  String?
  role                   UserRole  @default(DEFAULT)
  image                  String?   @map("user_image")
  preferences            Json?     @default("{}") @map("preferences")
  requiresPasswordReset  Boolean   @default(false) @map("requires_password_reset")
  companyId              String    @db.Uuid
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById            String?   @db.Uuid @map("created_by_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  projectHistories ProjectHistory[]

  @@index([email])
  @@index([companyId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("users")
}

model LoginAttempt {
  id        String    @id @default(uuid()) @db.Uuid
  ip        String
  email     String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([ip])
  @@map("login_attempts")
}

model Project {
  id              String       @id @default(uuid()) @db.Uuid
  companyId       String       @db.Uuid
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  type            ProjectType
  previewUrl      String?      @map("preview_url")
  isActive        Boolean      @default(true) @map("is_active")
  blogEnabled     Boolean      @default(false) @map("blog_enabled")
  deletedBy       String?      @map("deleted_by")
  deletionReason  String?      @map("deletion_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  pages              Page[]
  projectHistories   ProjectHistory[]
  blogCategories     BlogCategory[]
  blogTags           BlogTag[]
  blogPosts          BlogPost[]

  @@index([companyId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("projects")
}

model BlogCategory {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  description String?
  imageUrl    String?    @map("image_url")
  slug        String
  projectId   String     @db.Uuid @map("project_id")
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  posts       BlogPost[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("blog_categories")
}

model BlogTag {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  description String?
  imageUrl    String?       @map("image_url")
  slug        String
  projectId   String        @db.Uuid @map("project_id")
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  posts       BlogPostTag[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("blog_tags")
}

model BlogPost {
  id             String        @id @default(uuid()) @db.Uuid
  title          String
  subtitle       String?
  publishedAt    DateTime      @map("published_at")
  body           String        @db.Text
  coverImageUrl  String?       @map("cover_image_url")
  authorName     String        @map("author_name")
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @map("seo_description")
  seoKeywords    String?       @map("seo_keywords")
  projectId      String        @db.Uuid @map("project_id")
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  categoryId     String?       @db.Uuid @map("category_id")
  category       BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           BlogPostTag[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([categoryId])
  @@map("blog_posts")
}

model BlogPostTag {
  postId String   @db.Uuid @map("post_id")
  tagId  String   @db.Uuid @map("tag_id")
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model Page {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  content      Json?     @default("{}")
  schemaData   Json?     @default("{}") @map("schema_data")
  contentData  Json?     @default("{}") @map("content_data")
  previewUrl   String?   @map("preview_url")
  isPublished  Boolean   @default(false) @map("is_published")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([deletedAt])
  @@map("pages")
}

model ProjectHistory {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  previousState Json?
  newState      Json?
  version       Int
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([projectId])
  @@index([userId])
  @@map("project_histories")
}

