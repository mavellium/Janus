generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DEFAULT
  DEVELOPER

  @@map("user_role")
}

enum ProjectType {
  LANDING_PAGE
  INSTITUTIONAL

  @@map("project_type")
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED

  @@map("blog_post_status")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE

  @@map("audit_action")
}

model Company {
  id               String    @id @default(uuid()) @db.Uuid
  slug             String    @unique
  name             String
  description      String?
  logo             String?
  guestModeEnabled Boolean   @default(false) @map("guest_mode_enabled")
  webhookUrl       String?   @map("webhook_url")
  webhookToken     String?   @map("webhook_token")
  createdById      String?   @db.Uuid @map("created_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  users        User[]
  projects     Project[]
  guestEntries GuestEntry[]
  userCompanies UserCompany[]
  seoAnalyses  SeoAnalysis[]

  @@index([slug])
  @@index([deletedAt])
  @@index([createdById])
  @@map("companies")
}

model GuestEntry {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  companyId String   @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  posts     GuestPost[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([email, companyId])
  @@index([companyId])
  @@map("guest_entries")
}

model GuestPost {
  id        String   @id @default(uuid()) @db.Uuid
  title     String?
  message   String   @db.Text
  imageUrl  String
  mediaType String   @default("IMAGE")
  guestId   String   @db.Uuid
  guest     GuestEntry @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guestId])
  @@map("guest_posts")
}

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  email                  String    @unique
  password               String    @db.Text
  name                   String?
  phone                  String?
  role                   UserRole  @default(DEFAULT)
  permissions            String[]  @default([]) @map("permissions")
  image                  String?   @map("user_image")
  preferences            Json?     @default("{}") @map("preferences")
  requiresPasswordReset  Boolean   @default(false) @map("requires_password_reset")
  companyId              String?   @db.Uuid
  company                Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdById            String?   @db.Uuid @map("created_by_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  projectHistories ProjectHistory[]
  blogPosts        BlogPost[]       @relation("BlogPostAuthor")
  companies        UserCompany[]
  auditLogs        AuditLog[]
  seoAnalyses      SeoAnalysis[]

  @@index([email])
  @@index([companyId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("users")
}

model UserCompany {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid @map("user_id")
  companyId   String    @db.Uuid @map("company_id")
  permissions String[]  @default([]) @map("permissions")
  createdAt   DateTime  @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("user_companies")
}

model LoginAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  ip        String
  email     String?
  success   Boolean  @default(false)
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ip])
  @@index([createdAt])
  @@map("login_attempts")
}

model Project {
  id              String       @id @default(uuid()) @db.Uuid
  companyId       String       @db.Uuid
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  type            ProjectType
  previewUrl         String?      @map("preview_url")
  cmsSyncScriptUrl   String?      @map("cms_sync_script_url")
  cmsEnabled         Boolean      @default(false) @map("cms_enabled")
  ga4PropertyId      String?      @map("ga4_property_id")
  isActive           Boolean      @default(true) @map("is_active")
  blogEnabled        Boolean      @default(false) @map("blog_enabled")
  deletedBy       String?      @map("deleted_by")
  deletionReason  String?      @map("deletion_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  pages              Page[]
  projectHistories   ProjectHistory[]
  blogCategories     BlogCategory[]
  blogTags           BlogTag[]
  blogPosts          BlogPost[]
  siteScripts        SiteScript[]
  mediaAssets        MediaAsset[]

  @@index([companyId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("projects")
}

model BlogCategory {
  id             String              @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  imageUrl       String?             @map("image_url")
  slug           String
  seoTitle       String?             @map("seo_title")
  seoDescription String?             @map("seo_description")
  seoKeywords    String?             @map("seo_keywords")
  isActive       Boolean             @default(true) @map("is_active")
  projectId      String              @db.Uuid @map("project_id")
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId       String?             @db.Uuid @map("parent_id")
  parent         BlogCategory?       @relation("SubCategories", fields: [parentId], references: [id])
  children       BlogCategory[]      @relation("SubCategories")
  posts          BlogPostCategory[]
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([parentId])
  @@map("blog_categories")
}

model BlogTag {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  imageUrl       String?       @map("image_url")
  slug           String
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @map("seo_description")
  seoKeywords    String?       @map("seo_keywords")
  isActive       Boolean       @default(true) @map("is_active")
  projectId      String        @db.Uuid @map("project_id")
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId       String?       @db.Uuid @map("parent_id")
  parent         BlogTag?      @relation("SubTags", fields: [parentId], references: [id])
  children       BlogTag[]     @relation("SubTags")
  posts          BlogPostTag[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([parentId])
  @@map("blog_tags")
}

model BlogPost {
  id             String             @id @default(uuid()) @db.Uuid
  slug           String?            @map("slug")
  title          String
  subtitle       String?
  status         BlogPostStatus     @default(PUBLISHED) @map("status")
  publishedAt    DateTime?          @map("published_at")
  body           String             @db.Text
  coverImageUrl  String?            @map("cover_image_url")
  authorName     String             @map("author_name")
  authorId       String?            @db.Uuid @map("author_id")
  author         User?              @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  readingTime    Int?               @map("reading_time")
  seoTitle       String?            @map("seo_title")
  seoDescription String?            @map("seo_description")
  seoKeywords    String?            @map("seo_keywords")
  projectId      String             @db.Uuid @map("project_id")
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  categories     BlogPostCategory[]
  tags           BlogPostTag[]
  versions       BlogPostVersion[]
  comments       BlogComment[]
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([authorId])
  @@index([status])
  @@map("blog_posts")
}

model BlogPostCategory {
  postId     String       @db.Uuid @map("post_id")
  categoryId String       @db.Uuid @map("category_id")
  post       BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("blog_post_categories")
}

model BlogPostTag {
  postId String   @db.Uuid @map("post_id")
  tagId  String   @db.Uuid @map("tag_id")
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model BlogPostVersion {
  id             String   @id @default(uuid()) @db.Uuid
  postId         String   @db.Uuid @map("post_id")
  post           BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  title          String
  subtitle       String?
  body           String   @db.Text
  coverImageUrl  String?  @map("cover_image_url")
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  seoKeywords    String?  @map("seo_keywords")
  readingTime    Int?     @map("reading_time")
  createdById    String?  @db.Uuid @map("created_by_id")
  createdByName  String?  @map("created_by_name")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([postId])
  @@index([createdAt])
  @@map("blog_post_versions")
}

model MediaAsset {
  id          String   @id @default(uuid()) @db.Uuid
  url         String
  type        String   @default("IMAGE")
  fileName    String?  @map("file_name")
  projectId   String   @db.Uuid @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById String?  @db.Uuid @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([createdAt])
  @@map("media_assets")
}

model BlogComment {
  id         String   @id @default(uuid()) @db.Uuid
  postId     String   @db.Uuid @map("post_id")
  post       BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  body       String   @db.Text
  authorId   String?  @db.Uuid @map("author_id")
  authorName String   @map("author_name")
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([postId])
  @@map("blog_comments")
}

model Page {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  content      Json?     @default("{}")
  schemaData   Json?     @default("{}") @map("schema_data")
  contentData  Json?     @default("{}") @map("content_data")
  previewUrl   String?   @map("preview_url")
  isPublished  Boolean   @default(false) @map("is_published")
  isAdvanced   Boolean   @default(false) @map("is_advanced")
  uiSchema     Json?     @default("{}") @map("ui_schema")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([deletedAt])
  @@map("pages")
}

enum ScriptPosition {
  HEAD
  BODY_END

  @@map("script_position")
}

model SiteScript {
  id         String         @id @default(uuid()) @db.Uuid
  name       String
  code       String         @db.Text
  position   ScriptPosition @default(HEAD)
  isActive   Boolean        @default(true) @map("is_active")
  projectId  String         @db.Uuid @map("project_id")
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([isActive])
  @@map("site_scripts")
}

model ProjectHistory {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  previousState Json?
  newState      Json?
  version       Int
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([projectId])
  @@index([userId])
  @@map("project_histories")
}

model AuditLog {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String?     @db.Uuid @map("user_id")
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail        String?     @map("user_email")
  userName         String?     @map("user_name")
  impersonatedId   String?     @db.Uuid @map("impersonated_id")
  impersonatedName String?     @map("impersonated_name")
  companyId        String?     @db.Uuid @map("company_id")
  projectId        String?     @db.Uuid @map("project_id")
  action           AuditAction
  entity           String
  entityId         String      @map("entity_id")
  entityLabel      String?     @map("entity_label")
  oldData          Json?       @map("old_data")
  newData          Json?       @map("new_data")
  createdAt        DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([companyId])
  @@index([entity, entityId, createdAt])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum SeoAnalysisType {
  SEO

  @@map("seo_analysis_type")
}

model SeoAnalysis {
  id        String          @id @default(uuid()) @db.Uuid
  companyId String          @db.Uuid @map("company_id")
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String          @db.Uuid @map("user_id")
  user      User            @relation(fields: [userId], references: [id])
  projectId String?         @db.Uuid @map("project_id")
  targetUrl String          @map("target_url")
  type      SeoAnalysisType @default(SEO)
  score     Int
  checks    Json
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([companyId])
  @@index([createdAt])
  @@map("seo_analyses")
}
