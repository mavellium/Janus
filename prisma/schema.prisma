generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DEFAULT
  DEVELOPER

  @@map("user_role")
}

enum ProjectType {
  LANDING_PAGE
  INSTITUTIONAL

  @@map("project_type")
}

model Company {
  id            String    @id @default(uuid()) @db.Uuid
  slug          String    @unique
  name          String
  description   String?
  logo          String?
  createdById   String?   @db.Uuid @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  users    User[]
  projects Project[]

  @@index([slug])
  @@index([deletedAt])
  @@index([createdById])
  @@map("companies")
}

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  email                  String    @unique
  password               String    @db.Text
  name                   String?
  phone                  String?
  role                   UserRole  @default(DEFAULT)
  image                  String?   @map("user_image")
  preferences            Json?     @default("{}") @map("preferences")
  requiresPasswordReset  Boolean   @default(false) @map("requires_password_reset")
  companyId              String    @db.Uuid
  company                Company   @relation(fields: [companyId], references: [id])
  createdById            String?   @db.Uuid @map("created_by_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  projectHistories ProjectHistory[]

  @@index([email])
  @@index([companyId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("users")
}

model LoginAttempt {
  id        String    @id @default(uuid()) @db.Uuid
  ip        String
  email     String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([ip])
  @@map("login_attempts")
}

model Project {
  id              String       @id @default(uuid()) @db.Uuid
  companyId       String       @db.Uuid
  company         Company      @relation(fields: [companyId], references: [id])
  name            String
  type            ProjectType
  previewUrl      String?      @map("preview_url")
  isActive        Boolean      @default(true) @map("is_active")
  deletedBy       String?      @map("deleted_by")
  deletionReason  String?      @map("deletion_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  pages              Page[]
  projectHistories   ProjectHistory[]

  @@index([companyId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("projects")
}

model Page {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid
  project      Project   @relation(fields: [projectId], references: [id])
  name         String
  slug         String
  content      Json?     @default("{}")
  schemaData   Json?     @default("{}") @map("schema_data")
  contentData  Json?     @default("{}") @map("content_data")
  previewUrl   String?   @map("preview_url")
  isPublished  Boolean   @default(false) @map("is_published")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([deletedAt])
  @@map("pages")
}

model ProjectHistory {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  project       Project   @relation(fields: [projectId], references: [id])
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id])
  previousState Json?
  newState      Json?
  version       Int
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([projectId])
  @@index([userId])
  @@map("project_histories")
}

