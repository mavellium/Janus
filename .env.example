# Database
DATABASE_URL="postgresql://user:password@localhost:5433/database"

# NextAuth - IMPORTANTE: Defina o domínio correto em produção
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-dominio.com (SEM barra final)
AUTH_SECRET="seu-auth-secret-aleatorio"
NEXTAUTH_URL="http://localhost:3000" # Em produção: https://januscms.com.br

# BunnyCDN para upload de imagens
BUNNY_STORAGE_ZONE="seu-storage-zone"
BUNNY_ACCESS_KEY="sua-access-key"
BUNNY_HOST="storage.bunnycdn.com"
BUNNY_PULL_ZONE="seu-pull-zone.b-cdn.net"

# Google Analytics 4 (Service Account) — Resultados/Analytics
# A Service Account precisa ter acesso de leitura (Viewer) nas propriedades GA4.
# A private key deve manter os \n escapados em uma unica linha.
GA4_CLIENT_EMAIL="service-account@projeto.iam.gserviceaccount.com"
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GA4_PROJECT_ID="seu-projeto-gcp"
